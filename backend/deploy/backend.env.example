APP_NAME=bridgeability-backend
# Leave empty to auto-detect the latest runnable jar under target/.
APP_JAR=
JAVA_BIN=/usr/bin/java
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
APP_TIMEZONE=Asia/Shanghai

SPRING_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/rongzhiqiao?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=bridgeability
SPRING_DATASOURCE_PASSWORD=change-me
SPRING_SQL_INIT_MODE=never

SPRING_DATA_REDIS_HOST=127.0.0.1
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=
SPRING_DATA_REDIS_DATABASE=0

JWT_SECRET=change-this-secret-change-this-secret-change-this-secret
APP_PRIVACY_ENCRYPTION_SECRET=change-this-privacy-encryption-secret
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=BridgeAbility

APP_LOG_DIR=/opt/bridgeability/backend/logs
APP_RUN_DIR=/opt/bridgeability/backend/run
APP_LOG_FILE=/opt/bridgeability/backend/logs/application.log
JVM_HEAP_DUMP_PATH=/opt/bridgeability/backend/logs/heapdump.hprof
JVM_GC_LOG_FILE=/opt/bridgeability/backend/logs/gc.log

JVM_MEMORY_OPTS=-XX:InitialRAMPercentage=25.0 -XX:MaxRAMPercentage=70.0
JVM_GC_OPTS=-XX:+UseG1GC -XX:+ParallelRefProcEnabled -XX:MaxGCPauseMillis=200
JAVA_OPTS=
SPRING_ARGS=
